# =============================================================================
# GibFlow — .gitignore
# Hugo static site + npm (Tailwind CSS 4 / DaisyUI 5) + PaperMod submodule
# =============================================================================

# ── Hugo build output ─────────────────────────────────────────────────────────
# Generated by `hugo` / `hugo --minify`. Rebuilt on every deploy.
/public/

# Hugo's internal resource cache (processed images, fingerprinted CSS/JS).
# Regenerated automatically on `hugo` or `hugo server`.
/resources/

# Hugo build lock file — created at runtime, not needed in VCS.
.hugo_build.lock

# Hugo build stats (class/id list for Tailwind scanning).
# Regenerated on every build; we use explicit @source directives instead.
hugo_stats.json

# ── npm / Node ────────────────────────────────────────────────────────────────
# The whole point: commit package.json + package-lock.json,
# run `npm install` to restore node_modules locally or in CI.
node_modules/

# Optional npm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
# VS Code workspace settings are fine to commit; user-specific overrides are not.
.vscode/settings.json
.vscode/*.code-workspace
*.suo
*.user
*.swp
*~

# ── Netlify ───────────────────────────────────────────────────────────────────
# Local Netlify Dev state
.netlify/

# ── Stray files ───────────────────────────────────────────────────────────────
StelleMare
