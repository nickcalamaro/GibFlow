{{- /*
  layouts/_default/sitemap.xml — GibFlow custom sitemap
  ────────────────────────────────────────────────────────
  Extends Hugo's built-in sitemap template with:
    - Excludes taxonomy and term list pages (empty categories/tags)
    - Respects `sitemap.disable: true` in page front matter
    - Outputs W3C datetime format for <lastmod>
    - Includes <changefreq> and <priority> when set per-page or globally
*/ -}}
{{- $pages := slice -}}
{{- range .Data.Pages -}}
  {{- $skipKind := in (slice "taxonomy" "term") .Kind -}}
  {{- if and (not .Sitemap.Disable) (not $skipKind) -}}
    {{- $pages = $pages | append . -}}
  {{- end -}}
{{- end -}}
{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range $pages }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- if ge .Sitemap.Priority 0.0 }}
    <priority>{{ .Sitemap.Priority }}</priority>
    {{- end }}
  </url>
  {{- end }}
</urlset>
